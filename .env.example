# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# Flynet Discovery API key (sent as X-API-Key).
# SERVER-SIDE ONLY — never expose it to the browser.
# By default this app runs against staging and returns real Blackbird restaurant
# and location data. To go live, use a production key and pass
# `environment: "production"` where the clients are constructed (app/page.tsx,
# app/member-panel.tsx). Request a key through the Flynet developer portal.
API_KEY=""

# OAuth client credentials (from provisioning). CLIENT_SECRET is backend-only.
# These power the "Sign in with Blackbird" flow: /api/auth/login starts the
# authorization-code + PKCE flow, /callback exchanges the code server-side, and
# the tokens live in HttpOnly cookies (refresh handled automatically).
CLIENT_ID=""
CLIENT_SECRET=""

# Must exactly match a redirect URI registered for your OAuth app.
# NOTE: the staging edge blocks localhost/127.0.0.1 redirect URIs outright, so
# the sign-in flow can't run on a bare localhost URL. For local dev:
#   1. ngrok http 3000
#   2. Get https://<your-subdomain>.ngrok.app/callback whitelisted for your
#      OAuth app (Flynet developer portal).
#   3. Set it here and open the app via the ngrok URL (not localhost), so the
#      flow's cookies land on the same host.
REDIRECT_URI="https://<your-subdomain>.ngrok.app/callback"

# (Optional) A member OAuth access token (JWT) with the read:profile and
# read:wallets scopes. Set it to skip the sign-in flow and pin the member
# section to this token — handy for quick API poking. Leave blank to use the
# sign-in flow above. Staging tokens expire after 60 minutes.
ACCESS_TOKEN=""

MERCHANT_ID=""

# ── Environment (optional) ───────────────────────────────────────────────────
# Leave all three blank to target staging (the SDK's default). To go to
# production — gated by partner approval, with its own credential set issued at
# sign-off (client id/secret, API key, redirect URI, merchant id) — set:
#   API_BASE_URL="https://api.blackbird.xyz/flynet/v1"
#   AUTH_BASE_URL="https://api.blackbird.xyz/oauth"
#   AUTH_AUDIENCE="https://api.blackbird.xyz/flynet"
# and swap every credential above for its production counterpart.

API_BASE_URL="https://api.blackbird.xyz/flynet/v1"
AUTH_BASE_URL="https://api.blackbird.xyz/oauth"
AUTH_AUDIENCE="https://api.blackbird.xyz/flynet"
